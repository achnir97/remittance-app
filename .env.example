# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Backend API (use HTTPS in production — never plain HTTP)
EXPO_PUBLIC_API_URL=https://api.yourbridge.app

# Supabase — anon key is safe to use client-side (it's rate-limited and RLS-protected)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
